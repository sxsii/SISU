{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "SISU",
  "version":     "0.1.0",
  "identifier":  "com.sisu.desktop",

  "build": {
    "frontendDist":       "../dist",
    "devUrl":             "http://localhost:1420",
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "title":     "SISU — System Resource Manager",
        "width":     1200,
        "height":    760,
        "minWidth":  900,
        "minHeight": 600,
        "resizable": true,
        "center":    true,
        "closable":  true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath":       "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "SISU — System Resource Manager"
    }
  },

  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}